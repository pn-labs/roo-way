# =============================================================================
# roo-way — environment variable reference
#
# Two layers of config:
#
#   ENV-LEVEL  — set once on the Railway service (or export in your shell).
#                These are credentials and server-wide defaults that never
#                change between calls.
#
#   RUN-LEVEL  — sent per-request in the POST /run JSON body.
#                These override the script defaults for a single invocation.
#                The env vars below (ROO_*) are the server-side fallbacks used
#                when the caller omits the field.
# =============================================================================

# ── ENV-LEVEL: required ───────────────────────────────────────────────────────

# OpenRouter API key — forwarded as OPENROUTER_API_KEY to roo CLI
OPENROUTER_API_KEY=sk-or-...

# GitHub personal access token (needs repo + workflow scopes)
# Used by gh CLI (issue/PR operations) and git HTTPS push via entrypoint.sh
GH_TOKEN=ghp_...

# HTTPS clone URL of the target repository Roo will work on.
# The script clones this repo into a fresh temp directory on every run.
# GH_TOKEN is embedded into the URL automatically by entrypoint.sh, so a
# plain https:// URL (without credentials) is correct here.
REPO_URL=https://github.com/org/repo.git

# List of repos exposed in the UI dropdown (GET /repos).
# Accepts either a JSON array or a pipe-separated list of HTTPS clone URLs.
# If unset, falls back to REPO_URL above.
#   pipe-separated:  REPOS=https://github.com/org/repo1.git|https://github.com/org/repo2.git
#   JSON array:      REPOS=["https://github.com/org/repo1.git","https://github.com/org/repo2.git"]
REPOS=https://github.com/org/repo1.git|https://github.com/org/repo2.git

# ── ENV-LEVEL: optional ───────────────────────────────────────────────────────

# GitHub webhook HMAC secret — set the same value in your repo's webhook config.
# If unset, signature verification is skipped (not recommended in production).
WEBHOOK_SECRET=a-long-random-string

# HTTP port — Railway sets this automatically; only needed for local dev.
PORT=3000

# Default git committer identity written on auto-commits
GIT_USER_NAME=Roo Way
GIT_USER_EMAIL=roo-way@users.noreply.github.com

# ── RUN-LEVEL defaults ────────────────────────────────────────────────────────
# These are the server-side fallbacks. Any POST /run body field (provider/model/mode)
# takes precedence over these env vars for that invocation.

# roo --provider flag (any provider supported by roo CLI)
ROO_PROVIDER=openrouter

# roo --model flag
ROO_MODEL=anthropic/claude-opus-4-5

# roo --mode flag — if unset, each command picks its own default (e.g. feature-mode)
# ROO_MODE=code
